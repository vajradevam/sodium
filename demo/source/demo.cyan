// demo.cyan — Cyan language demo for the Sodium compiler pipeline
// Computes binomial coefficient C(10, 3) = 120 using recursive factorial

function factorial(n) {
    if (n <= 1) {
        return (1);
    } else {
        return (n * factorial(n - 1));
    }
}

var n = 10;
var k = 3;
var n_fact = factorial(n);
var k_fact = factorial(k);
var nk_fact = factorial(n - k);
var result = n_fact / (k_fact * nk_fact);
print(result);
return (result);
