var r1 = 1 && 1;  // 1
var r2 = 1 && 0;  // 0
var r3 = 0 && 1;  // 0
var r4 = 0 && 0;  // 0
var r5 = 1 || 1;  // 1
var r6 = 1 || 0;  // 1
var r7 = 0 || 1;  // 1
var r8 = 0 || 0;  // 0
var r9 = (1 < 2) && (2 < 3);  // 1
var r10 = (1 > 2) || (2 < 3);  // 1
var r11 = (3 == 3) && (4 != 5);  // 1
var r12 = (3 != 3) || (4 == 5);  // 0
var sum = r1 + r2 + r3 + r4 + r5 + r6 + r7 + r8 + r9 + r10 + r11 + r12;
return (sum);
