// Test: empty blocks and minimal statements
// Various edge cases with empty bodies

var ok = 1;

// ── Empty block as statement ──
{}

// ── Empty block in if body ──
if (1 == 1) {}

// ── Empty block in else body ──
if (0 == 1) {} else {}

// ── While loop with body ──
var i = 0;
while (i < 5) {
    i = i + 1;
}
if (i != 5) { ok = 0; }

// ── Do-while (executes once) ──
var dw_done = 0;
do {
    dw_done = 1;
} while (0 == 1);   // executes once, condition false, exits
if (dw_done != 1) { ok = 0; }

// ── For loop with body ──
var f_sum = 0;
for (var fi = 0; fi < 5; fi = fi + 1) {
    f_sum = f_sum + fi;
}
if (f_sum != 10) { ok = 0; }  // 0+1+2+3+4 = 10

// ── Switch with empty case body (fallthrough chain) ──
var sw_val = 0;
switch(2) {
    case 1:
    case 2:
        sw_val = 42;
    case 3:
}
if (sw_val != 42) { ok = 0; }

// ── Break in loop ──
var br_val = 0;
while (1 == 1) {
    br_val = 7;
    break;
}
if (br_val != 7) { ok = 0; }

// ── Void return from function ──
function do_nothing() {
    return;       // void return (no parens)
}
do_nothing();

// ── Const in global size ──
const ARR_SIZE = 5;
var arr[ARR_SIZE];
arr[0] = 10;
arr[4] = 50;
if (arr[0] != 10) { ok = 0; }
if (arr[4] != 50) { ok = 0; }

return(ok);
