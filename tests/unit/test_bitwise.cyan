// bitwise AND, OR, XOR, shift, NOT
var a = 6 & 3;
// a == 2 (110 & 011 = 010)
var b = 6 | 3;
// b == 7 (110 | 011 = 111)
var c = 6 ^ 3;
// c == 5 (110 ^ 011 = 101)
var d = 1 << 3;
// d == 8
var e = 16 >> 2;
// e == 4
var f = ~0;
// f == -1 (all bits inverted)
var g = ~(-1);
// g == 0
return(a + b + c + d + e);
