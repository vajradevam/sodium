// Test argc(), argv(), and print_str builtins

// --- argc() ---
// When run without extra arguments, argc should be 1 (the program name).
var ac = argc();
if (ac < 1) {
    return(1);  // fail: argc should never be < 1
}
if (ac != 1) {
    return(2);  // fail: expected argc == 1 when run without args
}

// --- argv(0) ---
var p = argv(0);
if (p == 0) {
    return(3);  // fail: argv(0) should not be null
}

// --- print_str ---
// Just ensure it doesn't crash
print_str("argc test: ok");
print_str("\n");

return(0);  // pass
